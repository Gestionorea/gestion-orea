generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String   @id @default(cuid())
  username                 String   @unique
  passwordHash             String
  role                     Role     @default(assistant)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  transactions             Transaction[]
  reconciledTransactions   Transaction[] @relation("TransactionReconciledBy")
  reimbursedAdvances       Transaction[] @relation("AdvanceReimbursedBy")

  @@map("users")
}

enum Role {
  owner
  accountant
  assistant
}

enum TransactionType {
  income
  expense
}

enum PaymentMethod {
  interac
  credit_card
  debit_card
  cash
  wire
  check
  preauthorized_debit
  other
}

enum Beneficiary {
  self
  company
  property
}

enum CategoryType {
  income
  expense
  both
}

enum PaymentSourceKind {
  card
  bank_account
  cash
  other
}

model Company {
  id             String          @id @default(cuid())
  name           String          @unique
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  properties     Property[]
  transactions   Transaction[]
  paymentSources PaymentSource[] @relation("CompanyPaymentSources")
}

model Property {
  id           String        @id @default(cuid())
  name         String
  address      String?
  companyId    String?
  company      Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]

  @@index([companyId])
}

model Category {
  id           String        @id @default(cuid())
  name         String        @unique
  type         CategoryType  @default(both)
  description  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
}

model PaymentSource {
  id             String            @id @default(cuid())
  name           String
  kind           PaymentSourceKind
  lastDigits     String?
  isPersonal     Boolean           @default(false)
  ownerCompanyId String?
  ownerCompany   Company?          @relation("CompanyPaymentSources", fields: [ownerCompanyId], references: [id], onDelete: SetNull)
  archived       Boolean           @default(false)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  transactions   Transaction[]

  @@index([ownerCompanyId])
  @@index([isPersonal])
  @@index([archived])
}

model Transaction {
  id              String          @id @default(cuid())
  type            TransactionType
  date            DateTime
  merchantName    String
  amountBeforeTax Decimal         @db.Decimal(12, 2)
  gst             Decimal?        @db.Decimal(12, 2)
  qst             Decimal?        @db.Decimal(12, 2)
  amountTotal     Decimal         @db.Decimal(12, 2)
  paymentMethod   PaymentMethod
  paymentSourceId String?
  paymentSource   PaymentSource?  @relation(fields: [paymentSourceId], references: [id], onDelete: SetNull)
  propertyId      String?
  property        Property?       @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  companyId       String?
  company         Company?        @relation(fields: [companyId], references: [id], onDelete: SetNull)
  beneficiary     Beneficiary     @default(company)
  invoiceNumber   String?
  justification   String?
  attachmentUrl   String?
  categoryId      String?
  category        Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdById     String
  createdBy       User            @relation(fields: [createdById], references: [id])
  reconciledAt    DateTime?
  reconciledById  String?
  reconciledBy    User?           @relation("TransactionReconciledBy", fields: [reconciledById], references: [id], onDelete: SetNull)
  isAdvance       Boolean         @default(false)
  reimbursedAt    DateTime?
  reimbursedById  String?
  reimbursedBy    User?           @relation("AdvanceReimbursedBy", fields: [reimbursedById], references: [id], onDelete: SetNull)
  reimbursementTransactionId String? @unique
  reimbursementTransaction   Transaction? @relation("AdvanceReimbursement", fields: [reimbursementTransactionId], references: [id], onDelete: SetNull)
  reimbursementOf            Transaction? @relation("AdvanceReimbursement")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([type, date])
  @@index([paymentSourceId])
  @@index([propertyId])
  @@index([companyId])
  @@index([categoryId])
  @@index([createdAt])
  @@index([reconciledAt])
  @@index([isAdvance, reimbursedAt])
}
