generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                @id @default(cuid())
  username               String                @unique
  passwordHash           String
  role                   Role                  @default(assistant)
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  transactions           Transaction[]
  reconciledTransactions Transaction[]         @relation("TransactionReconciledBy")
  reimbursedAdvances     Transaction[]         @relation("AdvanceReimbursedBy")
  bankStatementImports   BankStatementImport[] @relation("BankStatementUploadedBy")

  @@map("users")
}

enum Role {
  owner
  accountant
  assistant
}

enum TransactionType {
  income
  expense
}

enum PaymentMethod {
  interac
  credit_card
  debit_card
  cash
  wire
  check
  preauthorized_debit
  other
}

enum TaxRegime {
  taxable_qc
  exempt
  manual
}

enum Beneficiary {
  self
  company
  property
}

enum CategoryType {
  income
  expense
  both
}

enum PaymentSourceKind {
  card
  bank_account
  cash
  other
}

model Company {
  id             String          @id @default(cuid())
  name           String          @unique
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  properties     Property[]
  transactions   Transaction[]
  paymentSources PaymentSource[] @relation("CompanyPaymentSources")
}

model Property {
  id           String        @id @default(cuid())
  name         String
  address      String?
  companyId    String?
  company      Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]

  @@index([companyId])
}

model Category {
  id              String           @id @default(cuid())
  name            String           @unique
  type            CategoryType     @default(both)
  description     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  transactions    Transaction[]
  interacContacts InteracContact[]
}

model InteracContact {
  id                String    @id @default(cuid())
  name              String    @unique
  defaultCategoryId String?
  defaultCategory   Category? @relation(fields: [defaultCategoryId], references: [id], onDelete: SetNull)
  occurrences       Int       @default(1)
  lastSeenAt        DateTime  @default(now())
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([defaultCategoryId])
}

model PaymentSource {
  id                     String                @id @default(cuid())
  name                   String
  kind                   PaymentSourceKind
  lastDigits             String?
  isPersonal             Boolean               @default(false)
  ownerCompanyId         String?
  ownerCompany           Company?              @relation("CompanyPaymentSources", fields: [ownerCompanyId], references: [id], onDelete: SetNull)
  archived               Boolean               @default(false)
  statementColumnMapping Json?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  transactions           Transaction[]
  bankStatementImports   BankStatementImport[]

  @@index([ownerCompanyId])
  @@index([isPersonal])
  @@index([archived])
}

model BankStatementImport {
  id              String        @id @default(cuid())
  paymentSourceId String
  paymentSource   PaymentSource @relation(fields: [paymentSourceId], references: [id], onDelete: Cascade)
  filename        String
  oneDriveUrl     String?
  periodStart     DateTime
  periodEnd       DateTime
  rowsTotal       Int           @default(0)
  rowsImported    Int           @default(0)
  rowsDuplicate   Int           @default(0)
  rowsRejected    Int           @default(0)
  uploadedById    String
  uploadedBy      User          @relation("BankStatementUploadedBy", fields: [uploadedById], references: [id])
  transactions    Transaction[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([paymentSourceId, periodEnd])
  @@index([uploadedById])
}

model Transaction {
  id                         String               @id @default(cuid())
  type                       TransactionType
  date                       DateTime
  merchantName               String
  amountBeforeTax            Decimal              @db.Decimal(12, 2)
  gst                        Decimal?             @db.Decimal(12, 2)
  qst                        Decimal?             @db.Decimal(12, 2)
  amountTotal                Decimal              @db.Decimal(12, 2)
  taxRegime                  TaxRegime            @default(taxable_qc)
  paymentMethod              PaymentMethod
  paymentSourceId            String?
  paymentSource              PaymentSource?       @relation(fields: [paymentSourceId], references: [id], onDelete: SetNull)
  propertyId                 String?
  property                   Property?            @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  companyId                  String?
  company                    Company?             @relation(fields: [companyId], references: [id], onDelete: SetNull)
  beneficiary                Beneficiary          @default(company)
  invoiceNumber              String?
  justification              String?
  attachmentUrl              String?
  categoryId                 String?
  category                   Category?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdById                String
  createdBy                  User                 @relation(fields: [createdById], references: [id])
  reconciledAt               DateTime?
  reconciledById             String?
  reconciledBy               User?                @relation("TransactionReconciledBy", fields: [reconciledById], references: [id], onDelete: SetNull)
  isAdvance                  Boolean              @default(false)
  reimbursedAt               DateTime?
  reimbursedById             String?
  reimbursedBy               User?                @relation("AdvanceReimbursedBy", fields: [reimbursedById], references: [id], onDelete: SetNull)
  reimbursementTransactionId String?              @unique
  reimbursementTransaction   Transaction?         @relation("AdvanceReimbursement", fields: [reimbursementTransactionId], references: [id], onDelete: SetNull)
  reimbursementOf            Transaction?         @relation("AdvanceReimbursement")
  bankStatementImportId      String?
  bankStatementImport        BankStatementImport? @relation(fields: [bankStatementImportId], references: [id], onDelete: SetNull)
  dedupHash                  String?              @unique
  createdAt                  DateTime             @default(now())
  updatedAt                  DateTime             @updatedAt

  @@index([type, date])
  @@index([paymentSourceId])
  @@index([propertyId])
  @@index([companyId])
  @@index([categoryId])
  @@index([createdAt])
  @@index([reconciledAt])
  @@index([isAdvance, reimbursedAt])
  @@index([bankStatementImportId])
}
