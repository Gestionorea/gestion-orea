  "about": {
    "meta": {
      "title": "Gestion ORÉA | About",
      "description": "Discover the history, mission and values of Gestion ORÉA, your real estate management partner."
    },
    "header": {
      "title": "About ORÉA",
      "subtitle": "ORÉA is a real estate holding company specializing in the acquisition, management and enhancement of multi-residential assets in Quebec.",
      "positioning": "Built in Estrie since 2020, ORÉA now focuses its growth on Greater Montreal."
    },
    "buildingAlt": "ORÉA building",
    "ecosystem": {
      "title": "Supporting ecosystem",
      "subtitle": "ORÉA relies on an ecosystem of complementary businesses that support certain operations, management and development functions."
    },
    "mission": {
      "title": "Our mission",
      "text": "Acquire underperforming buildings, reposition them with discipline and operate them according to lasting standards of management, maintenance and rental quality.",
      "text2": "Through rigorous management, targeted renovations and disciplined execution, ORÉA repositions multi-residential buildings into quality living environments — better operated, better maintained and better suited to tenant expectations. Every project contributes to the lasting improvement of Quebec's housing stock."
    },
    "values": {
      "title": "What defines us",
      "rigor": {
        "title": "Operational rigor",
        "description": "Each asset is managed with operational discipline grounded in process, follow-through and quality of execution."
      },
      "longterm": {
        "title": "Long-term vision",
        "description": "We invest with a long-term horizon, with a view to durable ownership and progressive value creation."
      },
      "local": {
        "title": "Local roots",
        "description": "We focus our efforts on markets we know in depth, with a disciplined, ground-level local understanding."
      },
      "quality": {
        "title": "Asset quality",
        "description": "We believe that a well-maintained, well-operated and well-repositioned asset protects its value and improves its performance over time."
      }
    },
    "media": {
      "title": "Podcasts",
      "subtitle": "Olivier Lemieux shares his vision of multi-residential real estate."
    },
    "timeline": {
      "title": "Our growth",
      "subtitle": "Annual portfolio growth since 2020.",
      "added": "units acquired",
      "cumulative": "units acquired since 2020"
    },
    "team": {
      "title": "The founder",
      "bio1": "Olivier Lemieux has worked in the construction environment for more than ten years. In 2020, he undertook his first multi-residential real estate project, which he acquired, renovated and operated directly. That initial project marked the starting point of the path that would lead to the creation and development of ORÉA. Since then, the company has built an in-house execution capability focused on the repositioning and disciplined operation of residential assets in its target markets.",
      "bio2": "His path has been shaped in a demanding market environment marked by rising interest rates, cost pressure and tighter credit conditions. That reality has informed an approach grounded in adaptation, rigor and durability.",
      "bio3": "Building after building, ORÉA has strengthened its internal management structure and on-the-ground execution capacity, with a disciplined, long-term growth vision.",
      "bio4": "Father of three daughters, Olivier leads ORÉA with the conviction that only solid foundations stand the test of time."
    }
  },
